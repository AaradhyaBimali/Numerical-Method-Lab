def f(x):
    return (1/(1+x**2))
def simpson1by3(f,a,b,n):
    h = (b - a) / n
    s = f(a) + f(b)

    for i in range(1, n):
        x = a + i * h
        if i % 2 == 0:
            s = s + 2 * f(x)
        else:
            s = s + 4 * f(x)

    I = (h / 3) * s

    print("Integral =", I)

def main():
     a=int(input("Enter lower limit a"))
     b=int(input("Enter upper limit b"))
     n=int(input("Enter value of n"))
     simpson1by3(f,a,b,n)

if __name__=="__main__":
     main()

