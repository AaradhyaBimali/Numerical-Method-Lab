def f(x):
    return (1/(1+x**2))
def gausslegendre(f,a,b):
     w1=w2=1
     u1=(-1/3**(1/2))
     u2=(1/3**(1/2))
     x1=((b-a)/2)*u1+(a+b)/2
     x2=((b-a)/2)*u2+(a+b)/2
     I=((b-a)/2)*(w1*f(x1)+w2*f(x2))
     print("Integral is:",I)


def main():
     a=int(input("Enter lower limit a"))
     b=int(input("Enter upper limit b"))
     gausslegendre(f,a,b)

if __name__=="__main__":
     main()

