def f(x):
    return x**2
def trapezoid(f,a,b,n):
     h = (b - a) / n
     s = f(a) + f(b)

     for i in range(1, n):
          x = a + i * h
          s = s + 2 * f(x)

     I = (h / 2) * s

     print("Integral =", I)

def main():
     a=int(input("Enter lower limit a"))
     b=int(input("Enter upper limit b"))
     n=int(input("Enter value of n"))
     trapezoid(f,a,b,n)

if __name__=="__main__":
     main()

